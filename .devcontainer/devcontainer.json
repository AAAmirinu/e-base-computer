{
  "name": "E-base Computer",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "postCreateCommand": "python -m pip install -e . && python -m unittest discover -s tests",
  "forwardPorts": [8765],
  "portsAttributes": {
    "8765": {
      "label": "E-base Playground",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
